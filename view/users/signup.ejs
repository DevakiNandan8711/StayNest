<% layout("/layout/boilerplate") %>

<style>
    .auth-wrapper {
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        background: radial-gradient(circle at 10% 20%, rgba(254, 66, 77, 0.05) 0%, rgba(255, 255, 255, 0) 40%),
                    radial-gradient(circle at 90% 80%, rgba(254, 66, 77, 0.05) 0%, rgba(255, 255, 255, 0) 40%);
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 2rem;
        padding: 3rem 2.5rem;
        max-width: 450px;
        width: 100%;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        transition: transform 0.3s ease;
    }

    .auth-card:hover {
        transform: translateY(-5px);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .auth-header h1 {
        font-weight: 800;
        font-size: 2.25rem;
        color: #222222;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #222222, #555555);
        -webkit-background-clip: text;
        background-clip: text;
    }

    .auth-header p {
        color: #717171;
        font-size: 1rem;
    }

    .form-label {
        font-weight: 600;
        color: #484848;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        margin-left: 0.5rem;
    }

    .form-control {
        border-radius: 1rem;
        padding: 0.8rem 1.2rem;
        border: 1.5px solid #dddddd;
        background: rgba(255, 255, 255, 0.9);
        transition: all 0.2s ease;
    }

    .form-control:focus {
        border-color: #fe424d;
        box-shadow: 0 0 0 4px rgba(254, 66, 77, 0.1);
        background: #fff;
    }

    .btn-auth {
        background: #fe424d;
        color: white;
        border: none;
        padding: 0.9rem;
        border-radius: 1rem;
        font-weight: 700;
        width: 100%;
        margin-top: 1rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(254, 66, 77, 0.2);
    }

    .btn-auth:hover {
        background: #e31c2c;
        transform: scale(1.02);
        box-shadow: 0 6px 20px rgba(254, 66, 77, 0.3);
        color: white;
    }

    .auth-footer {
        text-align: center;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .auth-footer p {
        color: #717171;
        font-size: 0.9rem;
    }

    .auth-footer a {
        color: #fe424d;
        text-decoration: none;
        font-weight: 700;
        margin-left: 0.25rem;
    }

    .auth-footer a:hover {
        text-decoration: underline;
    }

    .icon-box {
        width: 60px;
        height: 60px;
        background: #fe424d;
        color: white;
        border-radius: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 1.5rem;
        box-shadow: 0 10px 20px rgba(254, 66, 77, 0.25);
    }
</style>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <div class="icon-box">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <h1>Welcome!</h1>
            <p>Create your StayNest account</p>
        </div>

        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input name="username" id="username" type="text" class="form-control" placeholder="e.g. wanderlust_jane" required>
                <div class="invalid-feedback">Please choose a username.</div>
                <div class="valid-feedback">Perfect!</div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <input name="email" id="email" type="email" class="form-control" placeholder="jane@example.com" required>
                <div class="invalid-feedback">Please enter a valid email.</div>
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <input name="password" id="password" type="password" class="form-control" placeholder="Create a secure password" required>
                <div class="invalid-feedback">Password is required.</div>
            </div>

            <button class="btn btn-auth">Create Account</button>
        </form>

        <div class="auth-footer">
            <p>Already have an account? <a href="/login">Log in</a></p>
        </div>
    </div>
</div>